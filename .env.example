# 日志（本地开发建议关闭请求体/响应体记录，避免录屏链接进入日志）
LOG_DIR=logs
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false

# 阿里百炼 / DashScope
# 用于带时间戳 ASR 和 Embedding。
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_ASR_MODEL=paraformer-v2

# 本地开发端口
SERVER_PORT=3100
CLIENT_DEV_PORT=8081
SERVER_HOST=localhost

# 可选：如果你有百炼业务空间专属域名，填完整 base URL。
# 例如：https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com
# 不填时后续代码可以回退到默认 DashScope 域名。
ALIYUN_DASHSCOPE_BASE_URL=

# 阿里 OSS
# 用于把录制或上传的音视频放到 ASR 能访问的位置。
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=

# 直播录制和音频处理
DOUYIN_LIVE_RECORDER_PATH=
DOUYIN_LIVE_RECORDER_PYTHON=
DOUYIN_LIVE_RECORDER_MAX_SECONDS=21600

# RAG 向量检索
ALIYUN_EMBEDDING_MODEL=text-embedding-v4
ALIYUN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_EMBEDDING_DIMENSIONS=1024

# DeepSeek 语义分析
# 用于结合 ASR 文本、RAG 依据和话术框架判断违禁词、语义风险、框架缺口。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 飞书文档同步
# 需要飞书开放平台应用开启 docx 文档创建/编辑权限。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOC_FOLDER_TOKEN=
